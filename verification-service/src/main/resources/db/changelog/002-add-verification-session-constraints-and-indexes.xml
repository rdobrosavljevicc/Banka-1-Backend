<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.17.xsd">

    <changeSet id="002-add-verification-session-constraints-and-indexes" author="codex">
        <addNotNullConstraint tableName="verification_sessions" columnName="operation_type" columnDataType="VARCHAR(50)"/>
        <addNotNullConstraint tableName="verification_sessions" columnName="related_entity_id" columnDataType="VARCHAR(255)"/>
        <addNotNullConstraint tableName="verification_sessions" columnName="created_at" columnDataType="TIMESTAMP"/>
        <addNotNullConstraint tableName="verification_sessions" columnName="expires_at" columnDataType="TIMESTAMP"/>
        <addNotNullConstraint tableName="verification_sessions" columnName="attempt_count" columnDataType="INT"/>
        <addNotNullConstraint tableName="verification_sessions" columnName="status" columnDataType="VARCHAR(50)"/>

        <createIndex tableName="verification_sessions" indexName="idx_verification_sessions_client_id">
            <column name="client_id"/>
        </createIndex>

        <createIndex tableName="verification_sessions" indexName="idx_verification_sessions_status_expires_at">
            <column name="status"/>
            <column name="expires_at"/>
        </createIndex>

        <sql>
            CREATE UNIQUE INDEX uk_verification_sessions_pending_unique
            ON verification_sessions (client_id, operation_type, related_entity_id)
            WHERE status = 'PENDING';
        </sql>
    </changeSet>
</databaseChangeLog>
