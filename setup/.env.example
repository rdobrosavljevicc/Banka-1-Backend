# =========================
# Server / Docker Config
# =========================
API_GATEWAY_PORT=80
USER_SERVER_PORT=8081

# =========================
# Database Config (Postgres)
# =========================
# For employee-service
DB_HOST=postgres_user
DB_PORT=5432
USER_EX_PORT=5433
DB_NAME=banka
DB_USER=postgres
DB_PASSWORD=postgres

# For notification-service
POSTGRES_HOST=postgres_notification
POSTGRES_PORT=5432
POSTGRES_EX_PORT=5434
POSTGRES_DB=notification_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# =========================
# RabbitMQ Config
# =========================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_LISTENER_ENABLED=true

# =========================
# Notification Service
# =========================
NOTIFICATION_SERVER_PORT=8006
NOTIFICATION_SERVICE_HOST=0.0.0.0
NOTIFICATION_SERVICE_PORT=8006
NOTIFICATION_EXCHANGE=employee.events
NOTIFICATION_QUEUE=notification-service-queue
NOTIFICATION_ROUTING_KEY=employee.#
NOTIFICATION_CARD_ROUTING_KEY=card.#
NOTIFICATION_CLIENT_ROUTING_KEY=client.#
NOTIFICATION_VERIFICATION_ROUTING_KEY=client.verification

NOTIFICATION_RETRY_MAX_RETRIES=4
NOTIFICATION_RETRY_DELAY_SECONDS=5
NOTIFICATION_RETRY_SCHEDULER_DELAY_MILLIS=1000

# =========================
# Client Service
# =========================
CLIENT_SERVER_PORT=8083
CLIENT_SERVICE_PORT=8083
CLIENT_SERVICE_URL=http://localhost/clients
CLIENT_SERVICE_DB_HOST=postgres_client
CLIENT_SERVICE_DB_PORT=5432
CLIENT_SERVICE_DB_EX_PORT=5435
CLIENT_SERVICE_DB_NAME=clientdb
CLIENT_SERVICE_DB_USER=postgres
CLIENT_SERVICE_DB_PASSWORD=postgres

# =========================
# Account Service
# =========================
ACCOUNT_SERVER_PORT=8084
ACCOUNT_DB_HOST=postgres_account
ACCOUNT_DB_INTERNAL_PORT=5432
ACCOUNT_DB_EX_PORT=5436
ACCOUNT_DB_NAME=accountdb
ACCOUNT_DB_USER=postgres
ACCOUNT_DB_PASSWORD=postgres
SERVICES_USER_URL=http://client-service:8083
SERVICES_VERIFICATION_URL=http://verification-service:8086
SERVICE_VERIFICATION_PORT=8086
SERVICES_EXCHANGE_URL=http://exchange-service:8085
SERVICE_EXCHANGE_PORT=8085
SERVICES_CARD_URL=http://card-service:8087

# =========================
# Transaction Service
# =========================
TRANSACTION_SERVER_PORT=8087

# =========================
# Transfer Service
# =========================
TRANSFER_SERVICE_PORT=8085
TRANSFER_DB_NAME=transferdb
TRANSFER_DB_USER=postgres
TRANSFER_DB_PASSWORD=postgres
TRANSFER_DB_EX_PORT=5437
# Host/port vars used by transfer-service to call other services
CLIENT_SERVICE_HOST=client-service
ACCOUNT_SERVICE_HOST=account-service
EXCHANGE_SERVICE_HOST=exchange-service
VERIFICATION_SERVICE_HOST=verification-service

# =========================
# Exchange Service
# =========================
EXCHANGE_SERVER_PORT=8085
EXCHANGE_DB_HOST=postgres_exchange
EXCHANGE_DB_PORT=5432
# NOTE: must differ from TRANSFER_DB_EX_PORT (5437)
EXCHANGE_DB_EX_PORT=5440
EXCHANGE_DB_NAME=exchange_db
EXCHANGE_DB_USER=postgres
EXCHANGE_DB_PASSWORD=postgres
TWELVE_DATA_API_KEY=replace_with_provider_api_key

# =========================
# Verification Service
# =========================
VERIFICATION_SERVER_PORT=8086
VERIFICATION_DB_HOST=postgres_verification
VERIFICATION_DB_INTERNAL_PORT=5432
VERIFICATION_DB_EX_PORT=5438
VERIFICATION_DB_NAME=verificationdb
VERIFICATION_DB_USER=postgres
VERIFICATION_DB_PASSWORD=postgres

# =========================
# Card Service
# =========================
CARD_SERVER_PORT=8087
CARD_DB_HOST=postgres_card
CARD_DB_INTERNAL_PORT=5432
CARD_DB_EX_PORT=5439
CARD_DB_NAME=card_db
CARD_DB_USER=postgres
CARD_DB_PASSWORD=postgres
SERVICES_CLIENT_URL=http://client-service:8083
SERVICES_ACCOUNT_URL=http://account-service:8084
# Card service calls verification service for OTP flows
CARD_REQUEST_VERIFICATION_EXPIRATION_MINUTES=15
CARD_CREATION_AUTOMATIC_DEFAULT_LIMIT=1000000

# =========================
# Security
# =========================
JWT_SECRET=OvoJeNekaDugackaTajnaSifraZaJwtKojuNeStavljamoUProperties

# =========================
# Frontend URLs
# =========================
USER_ACTIVATE_ACCOUNT_URL=http://localhost:4200/auth/activate-account?token=
USER_RESET_PASSWORD_URL=http://localhost:4200/reset-password?token=
CLIENT_ACTIVATE_ACCOUNT_URL=http://localhost:4200/auth/activate-client?token=
CLIENT_RESET_PASSWORD_URL=http://localhost:4200/reset-password?token=

# =========================
# Mail / SMTP Config
# =========================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true

# =========================
# Grafana
# =========================
GRAFANA_ADMIN_PASSWORD=admin

# =========================
# Logging
# =========================
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO

# =========================
# Skip verification for certain operations (e.g., during development/testing)
# =========================

SKIP_VERIFICATION=false
